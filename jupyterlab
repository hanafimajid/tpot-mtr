import numpy as np
from collections import deque

def extract_fitted_pipelines(reg2):
    """
    Take your trained MultiOutputTP instance and extract the fitted sklearn pipelines
    from each underlying TPOTRegressor.
    """
    pipes = []
    for j, reg in enumerate(reg2.regs):
        if not hasattr(reg, 'fitted_pipeline_'):
            raise ValueError(f"TPOT regressor #{j} is not fitted or missing fitted_pipeline_.")
        pipes.append(reg.fitted_pipeline_)
    return pipes  # list length = n_targets

class ChainedPipelines:
    """
    Reuses the set of per-target pipelines found by TPOT in a chained manner.
    For target j, features are [X, predicted y_0..y_{j-1}].
    """
    def __init__(self, pipelines):
        self.pipelines = pipelines
        self.m = len(pipelines)

    def predict_one(self, x_row):
        yhat = np.zeros(self.m, dtype=float)
        # sequentially predict targets using previous predictions as extra features
        for j in range(self.m):
            Xi = np.hstack([x_row, yhat[:j]])
            yhat[j] = self.pipelines[j].predict(Xi.reshape(1, -1))[0]
        return yhat

    def refit(self, X_win, Y_win):
        """
        Refit each per-target pipeline on the current window with chaining:
        target j sees [X, Y[:, :j]] as features and Y[:, j] as target.
        """
        for j, pipe in enumerate(self.pipelines):
            Xi = np.hstack([X_win, Y_win[:, :j]])
            yi = Y_win[:, j]
            pipe.fit(Xi, yi)

def prequential_stream(X_stream, Y_stream, pipelines,
                       kappa=0.2, W=2000, T=200, min_batch=200, seed=42):
    """
    Prequential evaluation with stochastic label reveal.
    - X_stream: (n_samples, n_features)
    - Y_stream: (n_samples, n_targets)
    - pipelines: list of fitted sklearn pipelines (one per target), from TPOT
    - kappa: probability a sample's full row label is revealed (per-sample labeling)
    - W: sliding window size for retraining
    - T: retrain cadence (every T samples)
    - min_batch: minimum labeled samples required before first refit
    Returns:
        preds: (n_samples, n_targets) predictions over time
        avg_rmae: final average RMAE across targets
        per_target_rmae: RMAE per target
    """
    rng = np.random.default_rng(seed)
    m = Y_stream.shape[1]
    chain = ChainedPipelines(pipelines)

    X_buf = deque(maxlen=W)
    Y_buf = deque(maxlen=W)

    # Running baseline from *revealed* labels only (prequential denominator)
    running_sum = np.zeros(m)
    running_cnt = np.zeros(m)

    # Accumulators for final RMAE: sum_i |y - yhat| and sum_i |y - ybar|
    num_sums = np.zeros(m)
    den_sums = np.zeros(m)

    preds = []

    for i in range(X_stream.shape[0]):
        x_i = np.asarray(X_stream[i]).ravel()
        y_i = np.asarray(Y_stream[i]).ravel()

        # 1) Predict with current pipelines (or zeros before first refit)
        yhat_i = chain.predict_one(x_i)
        preds.append(yhat_i)

        # 2) Reveal label with probability kappa (per-sample)
        reveal = rng.random() < kappa
        if reveal:
            # Compute baseline BEFORE updating with current label
            valid = running_cnt > 0
            if valid.any():
                ybar = np.zeros(m, dtype=float)
                ybar[valid] = running_sum[valid] / running_cnt[valid]

                num_sums[valid] += np.abs(y_i[valid] - yhat_i[valid])
                den_sums[valid] += np.abs(y_i[valid] - ybar[valid])

            # Update buffers and running baseline
            X_buf.append(x_i)
            Y_buf.append(y_i)
            running_sum += y_i
            running_cnt += 1

        # 3) Periodic refit on the labeled window
        if ((i + 1) % T == 0) and (len(X_buf) >= min_batch):
            X_win = np.asarray(X_buf)
            Y_win = np.asarray(Y_buf)
            chain.refit(X_win, Y_win)

    # Final RMAE (per target then averaged)
    per_target_rmae = num_sums / np.where(den_sums == 0, np.nan, den_sums)
    avg_rmae = np.nanmean(per_target_rmae)
    return np.vstack(preds), avg_rmae, per_target_rmae
